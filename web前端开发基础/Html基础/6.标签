<!--
表格标签
1.表格的结构
    <table>标签：表示一个表格
    <tr>标签:表示表格中的一行
    <td>标签：表示表格中的列
    <th>标签：表示表格中的表头
-->

<table style="boder: 1px solid black;border-collapse:collapse">
    <tr>
        <th style="border: 1px solid black;">姓名</th>
        <td style="border: 1px solid black;">张三</td>
    </tr>
    <!-- border-collapse：collapse 表示表格的边线进行合并-->
</table>

