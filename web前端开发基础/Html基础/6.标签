<!--
表单提交
1.表单属性设置
<form>标签表示表单标签，定义整体的表单区域
    action属性设置表单数据提交地址
    method属性设置表单提交的方式，一般有“GET”方式和“POST”方式，不区分大小写
2.表单元素属性设置
name属性：设置表单元素的名称，该名称是提交数据时的参数名
value属性：设置表单元素的值，该值是提交数据时参数名所对应的值
-->
<form action="https://www.baidu.com" method="GET">
    <p>
    <!-- for 根据id名给指定id的标签设置光标 -->
        <label for="name">用户名：</label>
        <input type="text" id="name" name="username">
    </p>
    <p>
        <label>性别：</label>
        <input type="radio" name="sex">男
        <input type="radio" name="sex">女
    </p>
    <p>
        <label>爱好：</label>
        <input type="checkbox" name="love">睡觉
        <input type="checkbox" name="love">打游戏
    </p>
    <p>
        <label>玉照：</label>
        <input type="file" name="pic">睡觉
    </p>
    <p>
        <label>个人描述：</label>
        <textarea name="desc"></textarea>
    </p>
    <p>
        <label>籍贯：</label>
        <select name="position">
            <option>北京</option>
            <option>河北</option>
            <option>深圳</option>
        </select>
    </p>
    <p>
        <input type="submit" value="提交">
        <input type="reset" value="重置">
        <input type="button" value="按钮">
    </p>
</form>

<!--get方式提交数据到web服务器以地址栏的方式提交给服务器不安全，能看到提交的数据
严谨的说是以查询参数的方式提交给web服务器
post方式提交数据表单数据会放到请求体里面
但是两者数据都以http协议的方式提交数据给web服务器
-->