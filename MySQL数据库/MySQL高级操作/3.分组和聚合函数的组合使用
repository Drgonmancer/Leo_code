1.数据准备
--创建“京东”数据库
create database jing_dong charset=utf8;

--使用“京东“数据库
use jing_dong;

--创建一个商品goods数据表
create table goods(
    id int unsigned primary key auto_increment not null,
    name varchar(15e) not null,
    cate_name varchar(4e) not null,
    brand_name varchar(40) not null,
    price decimal(ie,3) not null default 0,
    is_show bit not null default 0,
    is saleoff bit not null default 0
);

